<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Sign in to Netflix Clone — Stream your favourite movies and TV shows.">
  <title>Netflix — Sign In</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
</head>
<body class="auth-page">

  <!-- Background overlay -->
  <div class="bg-overlay"></div>

  <!-- Header -->
  <header class="auth-header">
    <div class="netflix-logo" aria-label="Netflix Clone">NETFLIX</div>
  </header>

  <!-- Login Card -->
  <main class="auth-main">
    <div class="auth-card" id="loginCard">
      <h1>Sign In</h1>

      <% if (flash.success) { %>
        <div class="alert alert-success" role="alert">
          <span class="alert-icon">✅</span> <%= flash.success %>
        </div>
      <% } %>
      <% if (flash.error) { %>
        <div class="alert alert-error" role="alert">
          <span class="alert-icon">⚠️</span> <%= flash.error %>
        </div>
      <% } %>

      <form class="auth-form" action="/login" method="POST" id="loginForm" novalidate>
        <div class="input-group">
          <input
            type="email"
            id="loginEmail"
            name="email"
            placeholder=" "
            required
            autocomplete="email"
          >
          <label for="loginEmail">Email or mobile number</label>
          <span class="input-border"></span>
        </div>

        <div class="input-group">
          <input
            type="password"
            id="loginPassword"
            name="password"
            placeholder=" "
            required
            autocomplete="current-password"
          >
          <label for="loginPassword">Password</label>
          <span class="input-border"></span>
          <button type="button" class="toggle-password" aria-label="Toggle password visibility" data-target="loginPassword">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
              <circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>

        <button type="submit" class="btn-primary" id="signinBtn">
          <span class="btn-text">Sign In</span>
          <div class="btn-spinner"></div>
        </button>
      </form>

      <div class="auth-divider"><span>OR</span></div>

      <button class="btn-secondary" type="button">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        Use a sign-in code
      </button>

      <div class="auth-links">
        <a href="#" class="forgot-link">Forgot password?</a>
        <label class="remember-me">
          <input type="checkbox" id="rememberMe"> Remember me
        </label>
      </div>

      <p class="auth-footer">
        New to Netflix? <a href="/signup">Sign up now.</a>
      </p>

      <p class="auth-disclaimer">
        This page is protected by Google reCAPTCHA to ensure you're not a bot.
        <a href="#">Learn more.</a>
      </p>
    </div>
  </main>

  <script src="/script.js"></script>
</body>
</html>
